programa {
  funcao inicio() {
    real n1, n2

    escreva ("DIgite um nķmero aleatůrio! \n>>>")
    leia (n1)

    escreva ("Digite outro nķmero! ")
    leia (n2)

    se ( n1 == n2) {
      escreva ("OS nķmeros s„o iguais!")
    }
    senao {
      escreva ("Os Nķmeros s„o diferentes!")
    }
  }
}
