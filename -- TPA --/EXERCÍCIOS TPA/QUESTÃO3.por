programa {
  funcao inicio() {
    real n1, n2, n3, n4, m

    escreva("Digite sua primeira nota! \n")
    leia (n1)
    escreva("Digite sua segunda nota! \n")
    leia (n2)
    escreva("Digite sua terceira senha! \n")
    leia (n3)
    escreva("Digite sua quarta nota! \n")
    leia (n4)

    m = (n1 + n2 + n3 + n4) / 4

    escreva("Sua mÈdia final È: ", m)
  }
}
