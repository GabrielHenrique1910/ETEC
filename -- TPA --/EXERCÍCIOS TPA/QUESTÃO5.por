programa {
  funcao inicio() {
    inteiro n1, n2, n3, p 

    escreva("Digite um n·mero:\n--> ")
    leia(n1)

    escreva("Digite outro n·mero:\n--> ")
    leia (n2)

    escreva("Digite mais um n·mero:\n--> ")
    leia (n3)

    p = n1 * n2 * n3 

    escreva("O produto dos trĻs n·meros digitados ķ:\n--> ", p)
  }
}
