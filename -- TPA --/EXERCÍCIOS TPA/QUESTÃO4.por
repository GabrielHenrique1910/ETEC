programa {
  funcao inicio() {
    real m, c, mm

    escreva("Digite um número em metros: \n--> ")
    leia(m)

    c = m * 100
    mm = c * 10

    escreva("O número digitado convertido para centimetros gera:\n--> ", c, " centimetros", "\nJá para a conversăo para milimetros gera:\n--> ", mm, " milimetros")
  }
}
